# Copy to .env and fill in real values.
# `python-dotenv` loads this at process start.

# Flask session-cookie signing key. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Google OAuth 2.0 Web application client id.
# Console -> APIs & Services -> Credentials -> Create OAuth client ID.
# Authorized JavaScript origin: http://localhost:5173
GOOGLE_CLIENT_ID=

# OpenAI credentials for the OCR scan endpoint (PR 6).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Contact email advertised in the User-Agent header to Nominatim (PR 4).
NOMINATIM_CONTACT_EMAIL=

# Set to "production" to disable the dev-only X-User-Id auth fallback.
FLASK_ENV=development
